Smart Alerts Logic

% Licenses Used = 
VAR SelectedProduct = VALUES(Product_Metadata[Product])

VAR LatestDate =
    CALCULATE(
        MAX(License_Usage[Date]),
        FILTER(
            License_Usage,
            License_Usage[Product] IN SelectedProduct
        )
    )

VAR LatestUsage =
    CALCULATE(
        SUM(License_Usage[Usage]),
        FILTER(
            License_Usage,
            License_Usage[Product] IN SelectedProduct
                && License_Usage[Date] = LatestDate
        )
    )

RETURN
    DIVIDE(LatestUsage, MAX(Product_Metadata[Total Licenses]))



License Alert = 
IF([% Licenses Used] > 0.9, 1, 0)



Smart Alert Count = 
CALCULATE(
    COUNTROWS(Product_Metadata),
    FILTER(
        Product_Metadata,
        [% Licenses Used] > 0.9
    )
)














