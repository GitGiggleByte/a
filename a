SlicerDepth =
VAR LineSelected = NOT ISFILTERED('Product Metadata'[Product Line])
VAR OwnerSelected = NOT ISFILTERED('Product Metadata'[Product Owner])
VAR ProductSelected = NOT ISFILTERED('Product Metadata'[Product])
RETURN
4 - (INT(LineSelected) + INT(OwnerSelected) + INT(ProductSelected))




ShowCDOCard =
IF(
    [SlicerDepth] = 1,
    1,
    BLANK()
)


ShowProductLineCard =
IF(
    [SlicerDepth] >= 2,
    CALCULATE(SELECTEDVALUE('Product Metadata'[Product Line])),
    BLANK()
)


ShowProductOwnerCard =
IF(
    [SlicerDepth] >= 3,
    CALCULATE(SELECTEDVALUE('Product Metadata'[Product Owner])),
    BLANK()
)


ShowProductCard =
IF(
    [SlicerDepth] = 4,
    CALCULATE(SELECTEDVALUE('Product Metadata'[Product])),
    BLANK()
)


ShowAlertsCard = 
VAR SlicerDepth = [SlicerDepth]  -- Assuming this measure returns values from 0 to 3
VAR AlertValue = [AlertCount]    -- Safe to use directly if AlertCount is a measure
RETURN
IF (
    SlicerDepth >= 0 && AlertValue > 0,
    1,
    0
)


