Smart Alerts Logic


% Licenses Used = 
VAR SelectedProduct = VALUES(Product_Metadata[Product])
VAR TotalUsage = 
    CALCULATE(
        SUM(License_Usage[Usage]),
        License_Usage[Product] IN SelectedProduct
    )
RETURN
    DIVIDE(TotalUsage, MAX(Product_Metadata[Total Licenses]))



License Alert = 
IF([% Licenses Used] > 0.9, 1, 0)



Smart Alert Count = 
CALCULATE(
    COUNTROWS(Product_Metadata),
    FILTER(
        Product_Metadata,
        [% Licenses Used] > 0.9
    )
)














