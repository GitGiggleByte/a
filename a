SlicerDepth =
VAR ProductSelected = HASONEVALUE(Product_Metadata[Product])
VAR OwnerSelected = HASONEVALUE(Product_Metadata[Product Owner])
VAR LineSelected = HASONEVALUE(Product_Metadata[CDO Product Line])
RETURN
SWITCH(
    TRUE(),
    ProductSelected, 4,
    OwnerSelected, 3,
    LineSelected, 2,
    1
)



